{
  "name": "gurgur",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun scripts/cli.ts dev",
    "start": "bun apps/server/src/index.ts",
    "build": "bun scripts/build.ts",
    "format": "oxfmt .",
    "lint": "oxlint . --deny-warnings --report-unused-disable-directives",
    "test": "bun test apps packages tools content",
    "typecheck": "tsc --noEmit",
    "check": "oxfmt --check . && bun run lint && bun run typecheck && bun run test",
    "content": "bun scripts/cli.ts content",
    "test:browser": "bun scripts/cli.ts test-browser",
    "test:network": "bun scripts/cli.ts test-network",
    "soak": "bun scripts/cli.ts soak"
  },
  "dependencies": {
    "@gurgur/engine": "workspace:*",
    "@gurgur/game": "workspace:*",
    "box3d.js": "0.0.2",
    "three": "0.185.1",
    "werift": "0.23.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/three": "0.185.1",
    "oxfmt": "^0.60.0",
    "oxlint": "^1.75.0",
    "playwright-core": "1.61.1",
    "typescript": "7.0.2"
  }
}
