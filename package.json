{
  "name": "gurgur",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "dev": "bun --watch apps/server/src/index.ts",
    "start": "bun apps/server/src/index.ts",
    "build": "bun scripts/build.ts",
    "compile:map": "bun tools/compile-map/src/index.ts",
    "render:player": "bun tools/render-player-billboard/src/index.ts",
    "setup:player-harness": "bun tools/render-player-billboard/src/index.ts --setup-only --save-harness",
    "generate:fgd": "bun tools/generate-fgd/src/index.ts",
    "setup:trenchbroom": "bun run generate:fgd && bun scripts/setup-trenchbroom.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint . --deny-warnings --report-unused-disable-directives",
    "smoke:browser": "bun scripts/smoke-browser.ts",
    "smoke:latency": "SMOKE_LATENCY_MS=150 bun scripts/smoke-browser.ts",
    "smoke:dynamic": "SMOKE_SCENARIO=dynamic-landing bun scripts/smoke-browser.ts",
    "smoke:push": "SMOKE_SCENARIO=dynamic-push SMOKE_LATENCY_MS=75 bun scripts/smoke-browser.ts",
    "smoke:grab": "SMOKE_SCENARIO=grab bun scripts/smoke-browser.ts",
    "smoke:touch": "SMOKE_SCENARIO=touch bun scripts/smoke-browser.ts",
    "smoke:gamepad": "SMOKE_SCENARIO=gamepad bun scripts/smoke-browser.ts",
    "smoke:reconnect": "SMOKE_SCENARIO=stale-session bun scripts/smoke-browser.ts",
    "harness:network": "bun tools/network-harness/src/run.ts",
    "harness:matrix": "bun tools/network-harness/src/matrix.ts",
    "soak:physics": "bun tools/physics-soak.ts",
    "soak:connections": "bun tools/connection-soak.ts",
    "soak:persistence": "bun tools/persistence-soak.ts",
    "test": "bun test apps packages tools content",
    "test:server": "bun test ./apps/server/test/server.integration.ts",
    "test:shutdown": "bun test ./apps/server/test/shutdown.integration.ts",
    "typecheck": "tsc --noEmit",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run test && bun run test:server && bun run test:shutdown"
  },
  "dependencies": {
    "@gurgur/entity-schema": "workspace:*",
    "@gurgur/world-compiler": "workspace:*",
    "box3d.js": "0.0.2",
    "three": "0.185.1"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/three": "0.185.1",
    "oxfmt": "^0.60.0",
    "oxlint": "^1.75.0",
    "playwright-core": "1.61.1",
    "typescript": "7.0.2"
  }
}
