{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "sortPackageJson": false,
  "ignorePatterns": [
    "content/generated/**",
    "content/maps/autosave/**",
    "data/**",
    "dist/**",
    "node_modules/**",
    "reports/**"
  ]
}
