{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "error"
  },
  "rules": {
    "consistent-function-scoping": "off",
    "no-underscore-dangle": "off",
    "unicorn/require-post-message-target-origin": "off"
  },
  "ignorePatterns": [
    "content/generated/**",
    "content/maps/autosave/**",
    "data/**",
    "dist/**",
    "node_modules/**",
    "**/node_modules/**",
    "reports/**"
  ]
}
